<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence cho số phiếu thưởng phạt -->
        <record id="seq_thuong_phat_phieu" model="ir.sequence">
            <field name="name">Phiếu Thưởng Phạt Sequence</field>
            <field name="code">thuong.phat.phieu</field>
            <field name="prefix">TP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
