<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job: Tự động tính lương vào 10h15 sáng ngày 15 hàng tháng -->
        <record id="ir_cron_tu_dong_tinh_luong" model="ir.cron">
            <field name="name">Tính Lương Tự Động (Ngày 15)</field>
            <field name="model_id" ref="model_bang_luong"/>
            <field name="state">code</field>
            <field name="code">model.cron_tu_dong_tinh_luong()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="nextcall" eval="(DateTime.now().replace(day=15, hour=3, minute=15, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <!-- Giờ UTC là 03:15 -> Tức là 10:15 giờ VN (GMT+7) -->
        </record>
    </data>
</odoo>
