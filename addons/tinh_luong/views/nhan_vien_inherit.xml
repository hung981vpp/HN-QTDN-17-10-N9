<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_bang_luong_graph_nhan_vien" model="ir.actions.act_window">
        <field name="name">Hợp đồng &amp; Lương</field>
        <field name="res_model">bang_luong</field>
        <field name="view_mode">graph,pivot,tree,form</field>
        <field name="domain">[('id_nhan_vien', '=', active_id)]</field>
        <field name="context">{'search_default_id_nhan_vien': active_id, 'default_id_nhan_vien': active_id}</field>
    </record>

    <record id="view_nhan_vien_form_inherit_tinh_luong" model="ir.ui.view">
        <field name="name">nhan_vien.form.inherit.tinh_luong</field>
        <field name="model">nhan_vien</field>
        <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(action_bang_luong_graph_nhan_vien)d" 
                        type="action" class="oe_stat_button" icon="fa-money"
                        groups="base.group_user">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Biểu Đồ Lương</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
