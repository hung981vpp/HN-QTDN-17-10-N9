<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view: Telegram Bot User -->
    <record id="view_telegram_bot_user_form" model="ir.ui.view">
        <field name="name">telegram.bot.user.form</field>
        <field name="model">telegram.bot.user</field>
        <field name="arch" type="xml">
            <form string="Telegram User">
                <sheet>
                    <group>
                        <group string="Thông tin Telegram">
                            <field name="telegram_chat_id"/>
                            <field name="is_verified" widget="boolean_toggle"/>
                            <field name="linked_date" readonly="1"/>
                            <field name="last_interaction" readonly="1"/>
                        </group>
                        <group string="Thông tin nhân viên">
                            <field name="id_nhan_vien"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_telegram_bot_user_list" model="ir.ui.view">
        <field name="name">telegram.bot.user.list</field>
        <field name="model">telegram.bot.user</field>
        <field name="arch" type="xml">
            <tree string="Danh sách Telegram Users">
                <field name="id_nhan_vien"/>
                <field name="telegram_chat_id"/>
                <field name="is_verified" widget="boolean"/>
                <field name="linked_date"/>
                <field name="last_interaction"/>
            </tree>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_telegram_bot_user_search" model="ir.ui.view">
        <field name="name">telegram.bot.user.search</field>
        <field name="model">telegram.bot.user</field>
        <field name="arch" type="xml">
            <search>
                <field name="id_nhan_vien"/>
                <field name="telegram_chat_id"/>
                <filter string="Đã xác thực" name="verified" domain="[('is_verified','=',True)]"/>
                <filter string="Chưa xác thực" name="not_verified" domain="[('is_verified','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_telegram_bot_user" model="ir.actions.act_window">
        <field name="name">Danh sách Telegram Users</field>
        <field name="res_model">telegram.bot.user</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có nhân viên nào liên kết Telegram!
            </p>
            <p>Hướng dẫn nhân viên gửi: <b>link &lt;số điện thoại&gt;</b> cho bot.</p>
        </field>
    </record>
</odoo>
