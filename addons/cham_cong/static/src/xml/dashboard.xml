<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="ChamCongDashboardMain">
        <div class="o_dashboard_cham_cong p-4" style="background-color: #f4f6f9; min-height: 100vh;">
            <div class="row mb-4">
                <div class="col-12">
                    <h2 class="text-primary font-weight-bold"><i class="fa fa-dashboard mr-2"></i> Tổng Quan Chấm Công</h2>
                    <p class="text-muted">Số liệu cập nhật thời gian thực (Real-time)</p>
                </div>
            </div>

            <!-- KPI Cards Row -->
            <div class="row d-flex justify-content-between mb-4">
                <!-- KPI 1 -->
                <div class="col-md-3">
                    <div class="card kpi-card shadow-sm border-0 d-flex flex-row wrap-card bg-white">
                        <div class="icon-box bg-primary-light text-primary">
                            <i class="fa fa-users fa-2x"></i>
                        </div>
                        <div class="info-box pl-3">
                            <h6 class="text-uppercase text-muted font-weight-bold mb-1">Check-in Hôm nay</h6>
                            <h3 class="font-weight-bold mb-0"><t t-esc="widget.kpi_data.checkins_today"/> <span class="text-small text-muted">/ <t t-esc="widget.kpi_data.total_employees"/></span></h3>
                        </div>
                    </div>
                </div>

                <!-- KPI 2 -->
                <div class="col-md-3">
                    <div class="card kpi-card shadow-sm border-0 d-flex flex-row wrap-card bg-white">
                        <div class="icon-box bg-warning-light text-warning">
                            <i class="fa fa-clock-o fa-2x"></i>
                        </div>
                        <div class="info-box pl-3">
                            <h6 class="text-uppercase text-muted font-weight-bold mb-1">Đi muộn Hôm nay</h6>
                            <h3 class="font-weight-bold mb-0 text-warning"><t t-esc="widget.kpi_data.lates_today"/></h3>
                            <small class="text-muted">Tháng này: <t t-esc="widget.kpi_data.lates_this_month"/></small>
                        </div>
                    </div>
                </div>

                <!-- KPI 3 -->
                <div class="col-md-3">
                    <div class="card kpi-card shadow-sm border-0 d-flex flex-row wrap-card bg-white">
                        <div class="icon-box bg-danger-light text-danger">
                            <i class="fa fa-file-text-o fa-2x"></i>
                        </div>
                        <div class="info-box pl-3">
                            <h6 class="text-uppercase text-muted font-weight-bold mb-1">Đơn từ Chờ duyệt</h6>
                            <h3 class="font-weight-bold mb-0 text-danger"><t t-esc="widget.kpi_data.pending_requests"/></h3>
                        </div>
                    </div>
                </div>
                
            </div>

            <!-- Charts Row -->
            <div class="row">
                <!-- Bar Chart: 7 Days Attendance -->
                <div class="col-md-8 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-0 pt-4 pb-0">
                            <h5 class="font-weight-bold text-dark mb-0">Tình hình đi làm 7 ngày qua</h5>
                        </div>
                        <div class="card-body">
                            <div class="chart-container" style="position: relative; height:40vh; width:100%">
                                <canvas id="attendanceBarChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Doughnut Chart: Leave Requests -->
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-0 pt-4 pb-0">
                            <h5 class="font-weight-bold text-dark mb-0">Tương quan Đơn Từ</h5>
                        </div>
                        <div class="card-body d-flex align-items-center justify-content-center">
                            <div class="chart-container" style="position: relative; height:35vh; width:100%">
                                <canvas id="leaveDoughnutChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
